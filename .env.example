# Vite-style env files (see https://cn.vite.dev/guide/env-and-mode):
#
#   .env                      # always loaded
#   .env.local                # always, gitignored
#   .env.[env]                # env only (e.g. .env.development)
#   .env.[env].local          # env only, gitignored
#
# Priority (low → high): .env < .env.local < .env.[env] < .env.[env].local
# Process env already set is never overwritten.
#
# INDIEBASE_ENV: development (default) | production
# Setup:
#   cp .env.example .env.development
#   docker compose --env-file .env.development up -d
#   cargo run -p api

INDIEBASE_ENV=development
INDIEBASE_HTTP_ADDR=0.0.0.0:8080

# Postgres (API + compose)
POSTGRES_HOST=postgres.indiebase2.orb.local
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=dev@indiebase.com
POSTGRES_DB=indiebase-dev
POSTGRES_PASSWORD_FILE=/run/secrets/pg_password
PGDATA=/var/lib/postgresql/data/pgdata

# Redis (API + compose)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=dev@indiebase.com

# PostgREST
POSTGREST_URL=http://localhost:13000
POSTGREST_PORT=13000
PGRST_DB_HOST=postgres
PGRST_OPENAPI_SERVER_PROXY_URI=http://localhost:13000
# Initial seed only for entrypoint when db-schemas file is missing.
# Do not inject as PostgREST env in compose (env overrides conf and blocks dynamic schemas).
PGRST_DB_SCHEMAS=public
PGRST_DB_ANON_ROLE=anon

# Host paths for PostgREST schema list + config (shared with compose volume).
# See docs/notes/postgrest-schema-reload.md
POSTGREST_SCHEMAS_FILE=./docker/postgrest/db-schemas
POSTGREST_CONFIG_PATH=./docker/postgrest/postgrest.conf

# Dashboard / Project opaque session TTL (seconds). Default 86400 (24h).
SESSION_TTL_SECS=86400

CONFIG_DIR=./docker

# Dev seed platform user (created on API startup / `just migrate` when INDIEBASE_ENV=development):
#   email:    admin@indiebase.local
#   password: dev@indiebase.com
# Login smoke: just run  # then just smoke-login
